// Implement a Priority Queue using an array. An element with smaller value has higher priority.

#include <stdio.h>

#define MAX 100

int pq[MAX];
int size = 0;

// Insert
void insert(int x) {
    if (size == MAX) {
        printf("Overflow\n");
        return;
    }
    pq[size++] = x;
}

// Find index of minimum element
int getMinIndex() {
    if (size == 0) return -1;

    int minIndex = 0;
    for (int i = 1; i < size; i++) {
        if (pq[i] < pq[minIndex]) {
            minIndex = i;
        }
    }
    return minIndex;
}

// Delete (remove highest priority → smallest element)
void deletePQ() {
    if (size == 0) {
        printf("Underflow\n");
        return;
    }

    int minIndex = getMinIndex();

    // Shift elements left
    for (int i = minIndex; i < size - 1; i++) {
        pq[i] = pq[i + 1];
    }

    size--;
}

// Peek
void peek() {
    if (size == 0) {
        printf("Empty\n");
        return;
    }

    int minIndex = getMinIndex();
    printf("%d\n", pq[minIndex]);
}

// Main
int main() {
    int N;
    scanf("%d", &N);

    char op[10];
    int x;

    for (int i = 0; i < N; i++) {
        scanf("%s", op);

        if (op[0] == 'i') {  // insert
            scanf("%d", &x);
            insert(x);
        }
        else if (op[0] == 'd') {  // delete
            deletePQ();
        }
        else if (op[0] == 'p') {  // peek
            peek();
        }
    }

    return 0;
}
