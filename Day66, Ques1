// Detect cycle in directed graph using DFS and recursion stack.

#include <stdio.h>
#include <stdlib.h>

#define MAX 100

int adj[MAX][MAX];   // Adjacency matrix
int visited[MAX];
int recStack[MAX];
int V;               // Number of vertices

// DFS function to detect cycle
int dfs(int node) {
    visited[node] = 1;
    recStack[node] = 1;

    for (int i = 0; i < V; i++) {
        if (adj[node][i]) {
            // If not visited, recur
            if (!visited[i] && dfs(i))
                return 1;
            // If already in recursion stack → cycle
            else if (recStack[i])
                return 1;
        }
    }

    recStack[node] = 0; // Remove from recursion stack
    return 0;
}

// Function to check cycle
int isCyclic() {
    for (int i = 0; i < V; i++) {
        if (!visited[i]) {
            if (dfs(i))
                return 1;
        }
    }
    return 0;
}

int main() {
    int E, u, v;

    printf("Enter number of vertices: ");
    scanf("%d", &V);

    printf("Enter number of edges: ");
    scanf("%d", &E);

    // Initialize arrays
    for (int i = 0; i < V; i++) {
        visited[i] = 0;
        recStack[i] = 0;
        for (int j = 0; j < V; j++) {
            adj[i][j] = 0;
        }
    }

    printf("Enter edges (u v) for directed graph:\n");
    for (int i = 0; i < E; i++) {
        scanf("%d %d", &u, &v);
        adj[u][v] = 1;  // Directed edge
    }

    if (isCyclic())
        printf("Cycle detected in the graph\n");
    else
        printf("No cycle in the graph\n");

    return 0;
}
