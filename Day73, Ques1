//Given a string s consisting of lowercase English letters, find and return the first character that does not repeat in the string. If all characters repeat, return '$'.

#include <stdio.h>
#include <string.h>

char nonRepeatingChar(char* s) {
    int freq[26] = {0};

    // Pass 1: count frequencies
    for (int i = 0; s[i] != '\0'; i++)
        freq[s[i] - 'a']++;

    // Pass 2: first char with freq == 1
    for (int i = 0; s[i] != '\0'; i++)
        if (freq[s[i] - 'a'] == 1)
            return s[i];

    return '$';
}

int main() {
    char s1[] = "geeksforgeeks";
    char s2[] = "aabbcc";
    char s3[] = "abcabd";
    char s4[] = "a";

    printf("Input: %-20s Output: %c\n", s1, nonRepeatingChar(s1));
    printf("Input: %-20s Output: %c\n", s2, nonRepeatingChar(s2));
    printf("Input: %-20s Output: %c\n", s3, nonRepeatingChar(s3));
    printf("Input: %-20s Output: %c\n", s4, nonRepeatingChar(s4));

    return 0;
}
