// Find shortest distances from source vertex in a weighted graph with non-negative weights.

#include <stdio.h>
#include <limits.h>
#include <stdbool.h>
#include <string.h>

#define MAXV 100005
#define MAXE 200005
#define INF  INT_MAX

// ── Adjacency list (edge-based) ──────────────────────────────────────────────
int head[MAXV], nxt[MAXE], to[MAXE], wt[MAXE], edgeCnt = 0;

void addEdge(int u, int v, int w) {
    to[edgeCnt]  = v;
    wt[edgeCnt]  = w;
    nxt[edgeCnt] = head[u];
    head[u]      = edgeCnt++;
}

// ── Min-Heap (priority queue) ─────────────────────────────────────────────────
typedef struct { int dist, node; } HeapNode;

HeapNode heap[MAXE];
int heapSize = 0;

void swap(int i, int j) {
    HeapNode tmp = heap[i];
    heap[i] = heap[j];
    heap[j] = tmp;
}

void push(int dist, int node) {
    heap[heapSize] = (HeapNode){dist, node};
    int i = heapSize++;
    // Bubble up
    while (i > 0) {
        int p = (i - 1) / 2;
        if (heap[p].dist > heap[i].dist) { swap(p, i); i = p; }
        else break;
    }
}

HeapNode pop() {
    HeapNode top = heap[0];
    heap[0] = heap[--heapSize];
    int i = 0;
    // Bubble down
    while (1) {
        int l = 2*i+1, r = 2*i+2, smallest = i;
        if (l < heapSize && heap[l].dist < heap[smallest].dist) smallest = l;
        if (r < heapSize && heap[r].dist < heap[smallest].dist) smallest = r;
        if (smallest != i) { swap(i, smallest); i = smallest; }
        else break;
    }
    return top;
}

// ── Dijkstra ──────────────────────────────────────────────────────────────────
int  dist[MAXV];
bool visited[MAXV];
int  V;

void dijkstra(int src) {
    for (int i = 0; i < V; i++) dist[i] = INF;
    dist[src] = 0;
    push(0, src);

    while (heapSize > 0) {
        HeapNode cur = pop();
        int u = cur.node;

        if (visited[u]) continue;   // stale entry — skip
        visited[u] = true;

        for (int e = head[u]; e != -1; e = nxt[e]) {
            int v = to[e], w = wt[e];
            if (!visited[v] && dist[u] != INF && dist[u] + w < dist[v]) {
                dist[v] = dist[u] + w;
                push(dist[v], v);   // push updated distance
            }
        }
    }
}

// ── Driver ────────────────────────────────────────────────────────────────────
int main() {
    int E, src;
    printf("Enter vertices, edges, source: ");
    scanf("%d %d %d", &V, &E, &src);

    memset(head,    -1,    sizeof(head));
    memset(visited, false, sizeof(visited));

    printf("Enter edges (u v w):\n");
    for (int i = 0; i < E; i++) {
        int u, v, w;
        scanf("%d %d %d", &u, &v, &w);
        addEdge(u, v, w);
        addEdge(v, u, w); // undirected — remove for directed
    }

    dijkstra(src);

    printf("\nShortest distances from vertex %d:\n", src);
    printf("%-10s %-10s\n", "Vertex", "Distance");
    printf("--------------------\n");
    for (int i = 0; i < V; i++) {
        if (dist[i] == INF) printf("%-10d %-10s\n", i, "INF");
        else                printf("%-10d %-10d\n", i, dist[i]);
    }

    return 0;
}
