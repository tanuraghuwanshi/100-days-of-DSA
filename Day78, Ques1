// Given weighted undirected graph, compute total weight of Minimum Spanning Tree using Prim’s algori

#include <stdio.h>
#include <limits.h>
#include <stdbool.h>

#define MAX 100

int graph[MAX][MAX];
int n; // number of vertices

// Find vertex with minimum key value not yet in MST
int minKey(int key[], bool inMST[]) {
    int min = INT_MAX, minIndex = -1;
    for (int v = 0; v < n; v++) {
        if (!inMST[v] && key[v] < min) {
            min = key[v];
            minIndex = v;
        }
    }
    return minIndex;
}

int primMST() {
    int  key[MAX];    // Minimum weight edge to include vertex
    int  parent[MAX]; // MST structure
    bool inMST[MAX];  // Tracks vertices included in MST

    // Initialize all keys as infinite, no vertex in MST
    for (int i = 0; i < n; i++) {
        key[i]   = INT_MAX;
        inMST[i] = false;
        parent[i] = -1;
    }

    key[0] = 0; // Start from vertex 0

    for (int count = 0; count < n - 1; count++) {
        int u = minKey(key, inMST); // Pick min key vertex not in MST
        inMST[u] = true;

        // Update key values of adjacent vertices
        for (int v = 0; v < n; v++) {
            if (graph[u][v] && !inMST[v] && graph[u][v] < key[v]) {
                key[v]    = graph[u][v];
                parent[v] = u;
            }
        }
    }

    // Calculate and display MST
    int totalWeight = 0;
    printf("\nEdge\t\tWeight\n");
    printf("-------------------\n");
    for (int i = 1; i < n; i++) {
        printf("%d -- %d\t\t%d\n", parent[i], i, graph[i][parent[i]]);
        totalWeight += graph[i][parent[i]];
    }

    return totalWeight;
}

int main() {
    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix (0 if no edge):\n");
    for (int i = 0; i < n; i++)
        for (int j = 0; j < n; j++)
            scanf("%d", &graph[i][j]);

    int totalWeight = primMST();
    printf("-------------------\n");
    printf("Total MST Weight: %d\n", totalWeight);

    return 0;
}
