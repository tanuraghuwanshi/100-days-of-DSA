#include <stdbool.h>
#include <string.h>

#define UNCOLORED  0
#define RED        1
#define BLUE      -1

bool isBipartite(int** graph, int n, int* graphColSize) {
    int color[100];
    memset(color, UNCOLORED, sizeof(color));

    int queue[100];

    // Loop handles disconnected graphs
    for (int start = 0; start < n; start++) {
        if (color[start] != UNCOLORED) continue;  // already visited

        // BFS from this component
        int front = 0, back = 0;
        queue[back++]  = start;
        color[start]   = RED;

        while (front < back) {
            int u = queue[front++];

            for (int i = 0; i < graphColSize[u]; i++) {
                int v = graph[u][i];

                if (color[v] == UNCOLORED) {
                    // Assign opposite color and enqueue
                    color[v] = -color[u];
                    queue[back++] = v;

                } else if (color[v] == color[u]) {
                    // Same color → not bipartite
                    return false;
                }
            }
        }
    }

    return true;
}
