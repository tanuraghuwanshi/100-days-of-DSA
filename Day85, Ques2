int findMin(int* nums, int numsSize) {
    int lo = 0, hi = numsSize - 1;

    while (lo < hi) {
        int mid = lo + (hi - lo) / 2;

        if (nums[mid] > nums[hi])
            lo = mid + 1;   // min is in the right half
        else
            hi = mid;       // min is in the left half (including mid)
    }

    return nums[lo];
}
