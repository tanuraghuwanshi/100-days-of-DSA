//  Detect cycle in directed graph using DFS and recursion stack.

#include <stdio.h>
#include <stdlib.h>
#include <stdbool.h>

#define MAX_VERTICES 100

// Adjacency list node
struct Node {
    int dest;
    struct Node* next;
};

// Graph structure
struct Graph {
    int vertices;
    struct Node* adjList[MAX_VERTICES];
};

// Create a new adjacency list node
struct Node* createNode(int dest) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->dest = dest;
    newNode->next = NULL;
    return newNode;
}

// Create a graph with V vertices
struct Graph* createGraph(int vertices) {
    struct Graph* graph = (struct Graph*)malloc(sizeof(struct Graph));
    graph->vertices = vertices;
    for (int i = 0; i < vertices; i++)
        graph->adjList[i] = NULL;
    return graph;
}

// Add a directed edge u -> v
void addEdge(struct Graph* graph, int u, int v) {
    struct Node* newNode = createNode(v);
    newNode->next = graph->adjList[u];
    graph->adjList[u] = newNode;
}

// DFS utility to detect cycle
// visited[]      -> tracks all fully processed nodes
// recStack[]     -> tracks nodes in the current DFS recursion path
bool dfsHasCycle(struct Graph* graph, int v, bool visited[], bool recStack[]) {
    // Mark current node as visited and add to recursion stack
    visited[v]  = true;
    recStack[v] = true;

    // Explore all adjacent vertices
    struct Node* adj = graph->adjList[v];
    while (adj != NULL) {
        int neighbor = adj->dest;

        if (!visited[neighbor]) {
            // Recurse on unvisited neighbor
            if (dfsHasCycle(graph, neighbor, visited, recStack))
                return true;
        } else if (recStack[neighbor]) {
            // Back edge found -> cycle exists
            return true;
        }

        adj = adj->next;
    }

    // Remove vertex from recursion stack before backtracking
    recStack[v] = false;
    return false;
}

// Main function to detect cycle in the entire graph
bool hasCycle(struct Graph* graph) {
    bool visited[MAX_VERTICES]  = {false};
    bool recStack[MAX_VERTICES] = {false};

    // Run DFS from every unvisited vertex (handles disconnected graphs)
    for (int i = 0; i < graph->vertices; i++) {
        if (!visited[i]) {
            if (dfsHasCycle(graph, i, visited, recStack))
                return true;
        }
    }
    return false;
}

// Free all allocated memory
void freeGraph(struct Graph* graph) {
    for (int i = 0; i < graph->vertices; i++) {
        struct Node* curr = graph->adjList[i];
        while (curr) {
            struct Node* temp = curr;
            curr = curr->next;
            free(temp);
        }
    }
    free(graph);
}

// ─── Driver ──────────────────────────────────────────────────────────────────
int main() {
    // Test 1: Graph WITH a cycle  (0→1→2→0)
    struct Graph* g1 = createGraph(4);
    addEdge(g1, 0, 1);
    addEdge(g1, 1, 2);
    addEdge(g1, 2, 0);   // back edge → cycle
    addEdge(g1, 2, 3);
    printf("Graph 1: %s\n", hasCycle(g1) ? "Cycle DETECTED" : "No cycle");
    freeGraph(g1);

    // Test 2: Graph WITHOUT a cycle  (DAG)
    struct Graph* g2 = createGraph(4);
    addEdge(g2, 0, 1);
    addEdge(g2, 0, 2);
    addEdge(g2, 1, 3);
    addEdge(g2, 2, 3);
    printf("Graph 2: %s\n", hasCycle(g2) ? "Cycle DETECTED" : "No cycle");
    freeGraph(g2);

    // Test 3: Disconnected graph with a cycle in one component
    struct Graph* g3 = createGraph(6);
    addEdge(g3, 0, 1);   // component A (no cycle)
    addEdge(g3, 3, 4);   // component B
    addEdge(g3, 4, 5);   //
    addEdge(g3, 5, 3);   // back edge → cycle
    printf("Graph 3: %s\n", hasCycle(g3) ? "Cycle DETECTED" : "No cycle");
    freeGraph(g3);

    return 0;
}
